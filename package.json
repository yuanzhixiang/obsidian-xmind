{
    "name": "xmind-maps",
    "packageManager": "pnpm@10.22.0",
    "author": "yuanzhixiang",
    "license": "Apache-2.0",
    "version": "0.1.7",
    "type": "module",
    "description": "View local XMind files.",
    "main": "src/main.ts",
    "scripts": {
        "dev": "pnpm exec concurrently \"pnpm exec rollup -c rollup.config.mjs -w --environment PRODUCTION:0\" \"pnpm start-obsidian\"",
        "build": "NODE_ENV=production pnpm exec rollup -c rollup.config.mjs --environment PRODUCTION:1",
        "lint": "pnpm exec eslint src",
        "format:viewer-assets": "pnpm exec prettier --write \"src/xmind-viewer-assets/mirror/assets.xmind.net/www/javascripts/*.js\" \"src/xmind-viewer-assets/mirror/assets.xmind.net/www/javascripts/73350.03dd088904.parts/**/*.js\" src/xmind-viewer-assets/mirror/assets.xmind.net/www/assets/vendor/js/snowbrush.js src/xmind-viewer-assets/local/embed-viewer.html debug/xmind-local-viewer/app.js src/xmind-viewer/runtime.cjs scripts/debug-xmind-local-viewer.mjs scripts/xmind-webpack-chunk-parts.mjs scripts/check-xmind-local-viewer-fix.mjs",
        "split:xmind-chunk": "node scripts/xmind-webpack-chunk-parts.mjs split",
        "check:xmind-chunk": "node scripts/xmind-webpack-chunk-parts.mjs check",
        "check:local-viewer": "node scripts/check-xmind-local-viewer-fix.mjs",
        "debug:xmind": "node scripts/debug-xmind-local-viewer.mjs",
        "package": "pnpm build && node scripts/package-plugin.mjs",
        "release": "pnpm package",
        "deploy:prod": "node scripts/deploy-prod.mjs",
        "start-obsidian": "node scripts/start-obsidian.mjs",
        "rollup": "rollup",
        "changelog": "pnpm dlx conventional-changelog-cli -p conventionalcommits -i check.md -s -r 1 --append"
    },
    "keywords": [],
    "devDependencies": {
        "@rollup/plugin-alias": "^5.1.0",
        "@rollup/plugin-commonjs": "^26.0.1",
        "@rollup/plugin-json": "^6.1.0",
        "@rollup/plugin-node-resolve": "^15.2.3",
        "@rollup/plugin-replace": "^5.0.7",
        "@rollup/plugin-terser": "^0.4.4",
        "@rollup/plugin-typescript": "^11.1.6",
        "@types/rollup": "^0.54.0",
        "@typescript-eslint/eslint-plugin": "^7.16.1",
        "@typescript-eslint/parser": "^7.16.1",
        "@typescript-eslint/utils": "^7.16.1",
        "auto-changelog": "^2.4.0",
        "concurrently": "^8.2.2",
        "eslint": "^8.57.0",
        "nodemon": "^3.1.4",
        "obsidian": "latest",
        "prettier": "^3.3.3",
        "ps-list": "^8.1.1",
        "rollup": "^4.20.0",
        "rollup-plugin-bundle-stats": "^4.13.4",
        "rollup-plugin-copy": "^3.5.0",
        "rollup-plugin-visualizer": "^5.12.0",
        "terser": "^5.31.3",
        "tslib": "^2.6.3",
        "typescript": "5.5.4"
    },
    "dependencies": {
        "@xmldom/xmldom": "0.8.10",
        "animejs": "3.2.1",
        "axios": "0.18.1",
        "backbone": "1.4.1",
        "base64-js": "1.5.1",
        "bootstrap": "4.0.0-beta.2",
        "buffer": "5.7.1",
        "commonmark": "0.30.0",
        "crypto-js": "4.2.0",
        "entities": "2.0.3",
        "file-saver": "1.3.8",
        "hammerjs": "2.0.7",
        "ieee754": "1.2.1",
        "inherits": "2.0.4",
        "jquery": "3.2.1",
        "js-cookie": "2.2.0",
        "jszip": "3.10.1",
        "localforage": "1.9.0",
        "lodash": "4.17.21",
        "mathjax-full": "3.1.2",
        "mobx": "6.13.7",
        "path-browserify": "1.0.1",
        "points": "3.2.0",
        "points-on-path": "0.2.1",
        "popper.js": "1.12.9",
        "process": "0.11.10",
        "svg-arc-to-cubic-bezier": "3.2.0",
        "svg-pathdata": "6.0.3",
        "svg-points": "6.0.1",
        "underscore": "1.13.6",
        "util": "0.10.4",
        "vue": "2.7.14",
        "vue-style-loader": "4.1.3"
    }
}
